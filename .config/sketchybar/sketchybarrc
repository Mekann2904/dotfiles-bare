# ./sketchybarrc
# Configures SketchyBar for Aerospace-driven workspace tiles.
# Exists to keep the bar minimal while reflecting active workspaces.
# Related files: plugins/aerospace.sh, plugins/update_workspace_icons.sh, plugins/workspace_events.sh, plugins/icon_map_fn.sh

# A simple sketchybar config for aerospace users to get started with
# Not too different from the base starting config!

PLUGIN_DIR="$CONFIG_DIR/plugins"
ITEM_DIR="$CONFIG_DIR/items"
export MIN_WORKSPACE=1

# デフォルトのワークスペース上限。環境変数WORKSPACE_RANGE_MAXを9にすれば即座に1-9へ戻せる。
export MAX_WORKSPACE_DEFAULT=7
export MAX_WORKSPACE="${WORKSPACE_RANGE_MAX:-$MAX_WORKSPACE_DEFAULT}"
export EXTRA_WORKSPACES="T D"
VISIBLE_ICON_SLOTS="${VISIBLE_ICON_SLOTS:-4}"
export VISIBLE_ICON_SLOTS

WALLPAPER_PRIMARY="/Users/mekann/obsidian/040 STORAGE/999 除外データ/Public/wallhaven-rqq3gm.png"
WALLPAPER_KITTY="/Users/mekann/obsidian/040 STORAGE/999 除外データ/Public/kitty.png"
WALLPAPER_E88X6R="/Users/mekann/obsidian/040 STORAGE/999 除外データ/Public/wallhaven-e88x6r.png"
WALLPAPER_8GG1DO="/Users/mekann/obsidian/040 STORAGE/999 除外データ/Public/wallhaven-8gg1do.jpg"
PREVIEW_DIR="$CONFIG_DIR/cache/wallpaper_previews"
WALLPAPER_POPUP_SIDE_INSET=220

desktop_width() {
  local bounds width
  bounds="$(osascript -e 'tell application "Finder" to get bounds of window of desktop' 2>/dev/null | tr -d '{}')"
  width="$(printf '%s' "$bounds" | awk -F', *' 'NF >= 3 { print $3 }')"

  if [ -n "$width" ] && [ "$width" -gt 0 ] 2>/dev/null; then
    printf '%s\n' "$width"
    return 0
  fi

  printf '%s\n' 1512
}

DISPLAY_WIDTH="$(desktop_width)"
WALLPAPER_POPUP_WIDTH=$(( (DISPLAY_WIDTH - WALLPAPER_POPUP_SIDE_INSET) / 4 ))

# 極端に広すぎたり狭すぎたりしないよう軽く制限する。
if [ "$WALLPAPER_POPUP_WIDTH" -lt 220 ]; then
  WALLPAPER_POPUP_WIDTH=220
fi

if [ "$WALLPAPER_POPUP_WIDTH" -gt 320 ]; then
  WALLPAPER_POPUP_WIDTH=320
fi

WALLPAPER_POPUP_PREVIEW_HEIGHT=$(( WALLPAPER_POPUP_WIDTH * 9 / 16 ))
PREVIEW_W="$WALLPAPER_POPUP_WIDTH"
PREVIEW_H="$WALLPAPER_POPUP_PREVIEW_HEIGHT"
mkdir -p "$PREVIEW_DIR"
WALLPAPER_PRIMARY_PREVIEW="$PREVIEW_DIR/wallhaven-rqq3gm.preview.png"
WALLPAPER_KITTY_PREVIEW="$PREVIEW_DIR/kitty.preview.png"
WALLPAPER_E88X6R_PREVIEW="$PREVIEW_DIR/wallhaven-e88x6r.preview.png"
WALLPAPER_8GG1DO_PREVIEW="$PREVIEW_DIR/wallhaven-8gg1do.preview.png"

# 表示サイズぴったりのプレビューを毎回作り直す。
# image.scale=1 のままでも見切れないよう、実表示サイズと揃える。
"$PLUGIN_DIR/wallpaper_preview.sh" "$WALLPAPER_PRIMARY" "$WALLPAPER_PRIMARY_PREVIEW" "$PREVIEW_W" "$PREVIEW_H"
"$PLUGIN_DIR/wallpaper_preview.sh" "$WALLPAPER_KITTY" "$WALLPAPER_KITTY_PREVIEW" "$PREVIEW_W" "$PREVIEW_H"
"$PLUGIN_DIR/wallpaper_preview.sh" "$WALLPAPER_E88X6R" "$WALLPAPER_E88X6R_PREVIEW" "$PREVIEW_W" "$PREVIEW_H"
"$PLUGIN_DIR/wallpaper_preview.sh" "$WALLPAPER_8GG1DO" "$WALLPAPER_8GG1DO_PREVIEW" "$PREVIEW_W" "$PREVIEW_H"

##### Bar Appearance #####
# Configuring the general appearance of the bar.
# These are only some of the options available. For all options see:
# https://felixkratz.github.io/SketchyBar/config/bar
# If you are looking for other colors, see the color picker:
# https://felixkratz.github.io/SketchyBar/config/tricks#color-picker

sketchybar --bar position=top height=40 blur_radius=30 color=0x40000000

##### Changing Defaults #####
# We now change some default values, which are applied to all further items.
# For a full list of all available item properties see:
# https://felixkratz.github.io/SketchyBar/config/items

default=(
  padding_left=5
  padding_right=5
  icon.font="Hack Nerd Font:Bold:10.0"
  label.font="Hack Nerd Font:Semibold:10.0"
  icon.color=0xffffffff
  label.color=0xffffffff
  icon.padding_left=2
  icon.padding_right=2
  label.padding_left=2
  label.padding_right=2
  updates=on
)
sketchybar --default "${default[@]}"

##### Adding aeropsace layouts #####

# Add the aerospace_workspace_change event we specified in aerospace.toml
sketchybar --add event aerospace_workspace_change
sketchybar --add event volume_change

# Add a fixed strip of workspaces 1 through $MAX_WORKSPACE
workspace_min=$MIN_WORKSPACE
workspace_max=$MAX_WORKSPACE

for sid in $(seq $workspace_min $workspace_max); do
  sketchybar --add item space.$sid left \
    --set space.$sid \
      drawing=on \
      background.drawing=off \
      padding_left=6 \
      padding_right=6 \
      icon="$sid" \
      icon.font="Hack Nerd Font:Semibold:16.0" \
      icon.color=0xffffffff \
      icon.padding_left=0 \
      icon.padding_right=4 \
      label="" \
      label.drawing=off \
      click_script="aerospace workspace $sid"

  icon_items=()
  for icon_slot in $(seq 1 "$VISIBLE_ICON_SLOTS"); do
    icon_items+=("space.$sid.icon${icon_slot}")
    sketchybar --add item space.$sid.icon${icon_slot} left \
      --set space.$sid.icon${icon_slot} \
        drawing=off \
        background.drawing=off \
        padding_left=2 \
        padding_right=2 \
        width=24 \
        icon.drawing=off \
        icon.width=16 \
        icon.background.drawing=off \
        icon.background.height=16 \
        icon.background.y_offset=0 \
        icon.background.corner_radius=3 \
        icon.background.image.scale=0.8 \
        label="" \
        label.drawing=off \
        click_script="aerospace workspace $sid"
  done

  # フォーカス中ワークスペースを下線で示す（色は白のまま）
  sketchybar --add bracket space.$sid.underline \
    space.$sid \
    "${icon_items[@]}" \
    space.$sid.more \
    --set space.$sid.underline \
      drawing=off \
      background.drawing=off \
      background.color=0xCCFFFFFF \
      background.height=2 \
      background.corner_radius=0 \
      background.padding_left=0 \
      background.padding_right=0 \
      background.y_offset=-12

  sketchybar --add item space.$sid.more left \
    --set space.$sid.more \
      drawing=off \
      padding_left=2 \
      padding_right=2 \
      background.drawing=off \
      width=24 \
      icon.drawing=off \
      label="" \
      label.drawing=off \
      label.font="Hack Nerd Font:Semibold:12.0" \
      label.color=0x99FFFFFF \
      label.padding_left=2 \
      label.padding_right=2 \
      click_script="aerospace workspace $sid"

  if [ "$sid" -lt $workspace_max ]; then
    sketchybar --add item space.$sid.separator left \
      --set space.$sid.separator \
        drawing=on \
        background.drawing=off \
        padding_left=8 \
        padding_right=8 \
        icon.drawing=off \
        label="|" \
        label.drawing=on \
        label.font="Hack Nerd Font:Semibold:13.0" \
        label.color=0x66FFFFFF
  fi
done

# 追加ワークスペース（T/D）を表示
special_workspaces=($EXTRA_WORKSPACES)
if [ "${#special_workspaces[@]}" -gt 0 ]; then
  sketchybar --add item space.special.separator left \
    --set space.special.separator \
      drawing=on \
      background.drawing=off \
      padding_left=8 \
      padding_right=8 \
      icon.drawing=off \
      label="|" \
      label.drawing=on \
      label.font="Hack Nerd Font:Semibold:13.0" \
      label.color=0x66FFFFFF
fi

for idx in "${!special_workspaces[@]}"; do
  sid="${special_workspaces[$idx]}"
  sketchybar --add item space.$sid left \
    --set space.$sid \
      drawing=on \
      background.drawing=off \
      padding_left=6 \
      padding_right=6 \
      icon="$sid" \
      icon.font="Hack Nerd Font:Semibold:16.0" \
      icon.color=0xffffffff \
      icon.padding_left=0 \
      icon.padding_right=4 \
      label="" \
      label.drawing=off \
      click_script="aerospace workspace $sid"

  icon_items=()
  for icon_slot in $(seq 1 "$VISIBLE_ICON_SLOTS"); do
    icon_items+=("space.$sid.icon${icon_slot}")
    sketchybar --add item space.$sid.icon${icon_slot} left \
      --set space.$sid.icon${icon_slot} \
        drawing=off \
        background.drawing=off \
        padding_left=2 \
        padding_right=2 \
        width=24 \
        icon.drawing=off \
        icon.width=16 \
        icon.background.drawing=off \
        icon.background.height=16 \
        icon.background.y_offset=0 \
        icon.background.corner_radius=3 \
        icon.background.image.scale=0.8 \
        label="" \
        label.drawing=off \
        click_script="aerospace workspace $sid"
  done

  sketchybar --add bracket space.$sid.underline \
    space.$sid \
    "${icon_items[@]}" \
    space.$sid.more \
    --set space.$sid.underline \
      drawing=off \
      background.drawing=off \
      background.color=0xCCFFFFFF \
      background.height=2 \
      background.corner_radius=0 \
      background.padding_left=0 \
      background.padding_right=0 \
      background.y_offset=-12

  sketchybar --add item space.$sid.more left \
    --set space.$sid.more \
      drawing=off \
      padding_left=2 \
      padding_right=2 \
      background.drawing=off \
      width=24 \
      icon.drawing=off \
      label="" \
      label.drawing=off \
      label.font="Hack Nerd Font:Semibold:12.0" \
      label.color=0x99FFFFFF \
      label.padding_left=2 \
      label.padding_right=2 \
      click_script="aerospace workspace $sid"

  if [ "$idx" -lt $((${#special_workspaces[@]} - 1)) ]; then
    sketchybar --add item space.$sid.separator left \
      --set space.$sid.separator \
        drawing=on \
        background.drawing=off \
        padding_left=8 \
        padding_right=8 \
        icon.drawing=off \
        label="|" \
        label.drawing=on \
        label.font="Hack Nerd Font:Semibold:13.0" \
        label.color=0x66FFFFFF
  fi
done

# 不可視アイテム: フォーカス表示を集約更新する。
sketchybar --add item workspace.focus center \
  --set workspace.focus \
    drawing=off \
    script="$CONFIG_DIR/plugins/aerospace_focus.sh" \
  --subscribe workspace.focus \
    aerospace_workspace_change \
    window_focused

# 不可視アイテム: イベント＋ポーリングでアイコンを更新する。
# ポーリングは取りこぼし対策の保険だけにする。
sketchybar --add item workspace.refresh center \
  --set workspace.refresh \
    drawing=off \
    script="$CONFIG_DIR/plugins/workspace_events.sh" \
    update_freq=${WORKSPACE_POLL_SECS:-5} \
  --subscribe workspace.refresh \
    window_created \
    window_destroyed \
    application_launched \
    application_terminated \
    front_app_switched \
    window_focused \
    aerospace_workspace_change

# Populate workspace tiles with the latest icons once on startup.
# 起動時も通常運用と同じ高速経路に寄せる。
"$PLUGIN_DIR/update_single_workspace.sh"

# Populate workspace focus styles once on startup.
"$PLUGIN_DIR/aerospace_focus.sh"




##### Adding Right Items #####
# In the same way as the left items we can add items to the right side.
# Additional position (e.g. center) are available, see:
# https://felixkratz.github.io/SketchyBar/config/items#adding-items-to-sketchybar

# Some items refresh on a fixed cycle, e.g. the clock runs its script once
# every 10s. Other gititems respond to events they subscribe to, e.g. the
# volume.sh script is only executed once an actual change in system audio
# volume is registered. More info about the event system can be found here:
# https://felixkratz.github.io/SketchyBar/config/events
# ここで十分な横幅を確保して時計テキストとの重なりを防ぐ
sketchybar --add item avatar right \
  --set avatar                                   \
      drawing=on                                 \
      icon=""                                    \
      icon.drawing=on                            \
      icon.padding_left=0                        \
      icon.padding_right=0                       \
      icon.background.drawing=on                 \
      icon.background.image="$PLUGIN_DIR/user3.png" \
      icon.background.image.scale=0.0125            \
      icon.background.width=16                   \
      icon.background.height=16                  \
      icon.background.corner_radius=8            \
      icon.background.y_offset=0                 \
      click_script="sketchybar --set avatar popup.drawing=on" \
      popup.background.color=0xF2000000 \
      popup.background.blur_radius=30 \
      popup.background.corner_radius=8 \
      popup.background.padding_left=12 \
      popup.background.padding_right=12 \
      popup.background.padding_top=10 \
      popup.background.padding_bottom=10 \
      popup.background.click_script="sketchybar --set avatar popup.drawing=off" \
      popup.align=right \
      popup.y_offset=6 \
      popup.height=$((WALLPAPER_POPUP_PREVIEW_HEIGHT + 10)) \
      padding_left=4                              \
      padding_right=4                             \
      width=24                                    \
      label.drawing=off                          \
      label.padding_left=0                       \
      label.padding_right=0

# プレビュー付きの壁紙選択ポップアップ。
# 画像だけのカードに絞り、縦並びで安定表示する。
add_wallpaper_popup_item() {
  local item_name="$1"
  local preview_path="$2"
  local source_path="$3"

  sketchybar --add item "$item_name" popup.avatar \
    --set "$item_name" \
      width="$WALLPAPER_POPUP_WIDTH" \
      icon.drawing=off \
      label.drawing=off \
      background.drawing=on \
      background.image="$preview_path" \
      background.image.scale=1 \
      background.width="$WALLPAPER_POPUP_WIDTH" \
      background.height="$WALLPAPER_POPUP_PREVIEW_HEIGHT" \
      background.corner_radius=12 \
      background.border_width=1 \
      background.border_color=0x22FFFFFF \
      background.padding_left=0 \
      background.padding_right=0 \
      background.padding_top=0 \
      background.padding_bottom=0 \
      click_script="$PLUGIN_DIR/wallpaper.sh \"$source_path\" avatar" \
      drawing=on
}

add_wallpaper_popup_item "avatar.wallpaper_primary" "$WALLPAPER_PRIMARY_PREVIEW" "$WALLPAPER_PRIMARY"
add_wallpaper_popup_item "avatar.wallpaper_kitty" "$WALLPAPER_KITTY_PREVIEW" "$WALLPAPER_KITTY"
add_wallpaper_popup_item "avatar.wallpaper_e88x6r" "$WALLPAPER_E88X6R_PREVIEW" "$WALLPAPER_E88X6R"
add_wallpaper_popup_item "avatar.wallpaper_8gg1do" "$WALLPAPER_8GG1DO_PREVIEW" "$WALLPAPER_8GG1DO"

sketchybar --add item clock right \
  --set clock update_freq=1 script="$PLUGIN_DIR/clock.sh" \
