# ./sketchybarrc
# Configures SketchyBar for Aerospace-driven workspace tiles.
# Exists to keep the bar minimal while reflecting active workspaces.
# Related files: plugins/aerospace.sh, plugins/update_workspace_icons.sh, plugins/workspace_events.sh, plugins/icon_map_fn.sh

# A simple sketchybar config for aerospace users to get started with
# Not too different from the base starting config!

PLUGIN_DIR="$CONFIG_DIR/plugins"
ITEM_DIR="$CONFIG_DIR/items" 
##### Bar Appearance #####
# Configuring the general appearance of the bar.
# These are only some of the options available. For all options see:
# https://felixkratz.github.io/SketchyBar/config/bar
# If you are looking for other colors, see the color picker:
# https://felixkratz.github.io/SketchyBar/config/tricks#color-picker

sketchybar --bar position=top height=40 blur_radius=30 color=0x40000000

##### Changing Defaults #####
# We now change some default values, which are applied to all further items.
# For a full list of all available item properties see:
# https://felixkratz.github.io/SketchyBar/config/items

default=(
  padding_left=5
  padding_right=5
  icon.font="Hack Nerd Font:Bold:10.0"
  label.font="SF Pro:Semibold:10.0"
  icon.color=0xffffffff
  label.color=0xffffffff
  icon.padding_left=2
  icon.padding_right=2
  label.padding_left=2
  label.padding_right=2
  updates=on
)
sketchybar --default "${default[@]}"

##### Adding aeropsace layouts #####

# Add the aerospace_workspace_change event we specified in aerospace.toml
sketchybar --add event aerospace_workspace_change

# Add a fixed strip of workspaces 1 through 7
workspace_min=1
workspace_max=7

for sid in $(seq $workspace_min $workspace_max); do
  sketchybar --add item space.$sid left \
    --subscribe space.$sid aerospace_workspace_change \
    --set space.$sid \
      drawing=on \
      background.drawing=off \
      padding_left=8 \
      padding_right=2 \
      icon="$sid" \
      icon.font="SF Pro:Semibold:16.0" \
      icon.color=0xffffffff \
      icon.padding_left=0 \
      icon.padding_right=4 \
      label="" \
      label.drawing=off \
      click_script="aerospace workspace $sid" \
      script="$CONFIG_DIR/plugins/aerospace.sh $sid"

  for icon_slot in 1 2 3 4; do
    sketchybar --add item space.$sid.icon${icon_slot} left \
      --set space.$sid.icon${icon_slot} \
        drawing=off \
        background.drawing=off \
        padding_left=3 \
        padding_right=3 \
        width=24 \
        icon.drawing=off \
        icon.width=16 \
        icon.background.drawing=off \
        icon.background.height=16 \
        icon.background.y_offset=0 \
        icon.background.corner_radius=3 \
        icon.background.image.scale=0.8 \
        label="" \
        label.drawing=off \
        click_script="aerospace workspace $sid"
  done

  sketchybar --add item space.$sid.more left \
    --set space.$sid.more \
      drawing=off \
      padding_left=3 \
      padding_right=6 \
      background.drawing=off \
      width=24 \
      icon.drawing=off \
      label="" \
      label.drawing=off \
      label.font="SF Pro:Semibold:12.0" \
      label.color=0x99FFFFFF \
      label.padding_left=2 \
      label.padding_right=2 \
      click_script="aerospace workspace $sid"

  if [ "$sid" -lt $workspace_max ]; then
    sketchybar --add item space.$sid.separator left \
      --set space.$sid.separator \
        drawing=on \
        background.drawing=off \
        padding_left=8 \
        padding_right=8 \
        icon.drawing=off \
        label="|" \
        label.drawing=on \
        label.font="SF Pro:Semibold:13.0" \
        label.color=0x66FFFFFF
  fi
done

# 不可視アイテムを用意してワークスペースアイコン更新を1回に集約する。
sketchybar --add item workspace.refresh center \
  --set workspace.refresh \
    drawing=off \
    script="$CONFIG_DIR/plugins/workspace_events.sh" \
  --subscribe workspace.refresh \
    window_created \
    window_destroyed \
    application_launched \
    application_terminated \
    front_app_switched \
    window_focused \
    aerospace_workspace_change

# Populate workspace tiles with the latest icons once on startup.
sh "$PLUGIN_DIR/update_workspace_icons.sh"




##### Adding Right Items #####
# In the same way as the left items we can add items to the right side.
# Additional position (e.g. center) are available, see:
# https://felixkratz.github.io/SketchyBar/config/items#adding-items-to-sketchybar

# Some items refresh on a fixed cycle, e.g. the clock runs its script once
# every 10s. Other gititems respond to events they subscribe to, e.g. the
# volume.sh script is only executed once an actual change in system audio
# volume is registered. More info about the event system can be found here:
# https://felixkratz.github.io/SketchyBar/config/events
sketchybar --add item avatar right \
  --set avatar                                   \
      drawing=on                                 \
      icon=""                                    \
      icon.drawing=on                            \
      icon.padding_left=0                        \
      icon.padding_right=0                       \
      icon.background.drawing=on                 \
      icon.background.image="$PLUGIN_DIR/user.png" \
      icon.background.image.scale=0.15            \
      icon.background.width=16                   \
      icon.background.height=16                  \
      icon.background.corner_radius=8            \
      icon.background.y_offset=0                 \
      # ここで十分な横幅を確保して時計テキストとの重なりを防ぐ
      padding_left=8                              \
      padding_right=8                             \
      width=28                                    \
      label.drawing=off                          \
      label.padding_left=0                       \
      label.padding_right=0

sketchybar --add item clock right \
  --set clock update_freq=10 script="$PLUGIN_DIR/clock.sh" \
  --add item volume right \
  --set volume script="$PLUGIN_DIR/volume.sh" \
  --subscribe volume volume_change \
  --add item battery right \
  --set battery update_freq=120 script="$PLUGIN_DIR/battery.sh" \
  --subscribe battery system_woke power_source_change \

sketchybar --add item ram right \
   --set ram script="$PLUGIN_DIR/ram_min.sh" \
            update_freq=15 \
            icon="RAM" \
            icon.padding_left=8 \
            icon.padding_right=4 \
            label.padding_right=8

##### Force all scripts to run the first time (never do this in a script) #####
sketchybar --update
