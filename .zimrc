#
# This is not sourced during shell startup and is only used to configure zimfw.
#

#
# Modules
#

# Sets sane Zsh built-in environment options.
zmodule environment
# Provides handy git aliases and functions.
zmodule git
# Applies correct bindkeys for input events.
zmodule input
# Sets a custom terminal title.
zmodule termtitle
# Utility aliases and functions. Adds colour to ls, grep and less.
zmodule utility

# Homebrew / fzf まわり（お好みで有効化）
# Homebrew 関連の補助機能（brew doctor などの補助）
zmodule homebrew
# fzf の連携関数（fzf 自体は brew で入っている前提）
zmodule fzf

# <-- Normally new modules should be added here. Check each module documentation
# for any caveats.

#
# Prompt
#

# Exposes how long the last command took to run to prompts.
zmodule duration-info
# Exposes git repository status information to prompts.
zmodule git-info
# A heavily reduced, ASCII-only version of the Spaceship and Starship prompts.
zmodule asciiship

#
# Completion
#

# Additional completion definitions for Zsh.
zmodule zsh-users/zsh-completions --fpath src
# Enables and configures smart and extensive tab completion, must be sourced
# after all modules that add completion definitions.
zmodule completion
# fzf-tab: fzf を使った補完 UI。completion のあとに置く。
zmodule Aloxaf/fzf-tab

#
# Modules that must be initialized last
#

# Syntax highlighting
# どちらか片方だけ使うこと。好みで選んでOK。

# パターン:
# - zsh-users/zsh-syntax-highlighting: メジャーで無難
# - zdharma-continuum/fast-syntax-highlighting: 高速で機能多め

# 例1: 従来どおり zsh-syntax-highlighting を使う場合
# zmodule zsh-users/zsh-syntax-highlighting

# 例2: fast-syntax-highlighting に乗り換える場合（おすすめ）
zmodule zdharma-continuum/fast-syntax-highlighting

# Fish-like autosuggestions for Zsh.
# Add the following to your ~/.zshrc to boost performance: ZSH_AUTOSUGGEST_MANUAL_REBIND=1
zmodule zsh-users/zsh-autosuggestions
# Clipboard plugin
zmodule Mekann2904/zsh-clipboard --source clipboard.plugin.zsh
zmodule Mekann2904/zsh-git --source git.plugin.zsh
zmodule Mekann2904/zsh-kitty --source kitty.plugin.zsh
zmodule olets/zsh-abbr

