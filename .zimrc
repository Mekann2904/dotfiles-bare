# -----------------------------------------------------------------------------
# Zim initialization config (.zimrc)
# このファイルは Zsh 起動時には直接は読まれず、zimfw の設定にのみ使う。
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# 基本モジュール（順序重要）
# -----------------------------------------------------------------------------
zmodule environment          # Zsh 組み込みオプションの sane 設定
zmodule git                  # git エイリアス/関数
zmodule input                # 入力系の bindkey
zmodule termtitle            # 端末タイトル設定
zmodule utility              # ls/grep/less のカラー等のユーティリティ

# Homebrew / fzf（必要なら有効化）
zmodule homebrew             # brew 補助（doctor 等）
zmodule fzf                  # fzf 連携（fzf は別途インストール前提）

# -----------------------------------------------------------------------------
# プロンプト
# -----------------------------------------------------------------------------
#zmodule duration-info        # 直前のコマンド実行時間をプロンプトへ
#zmodule git-info             # git ステータスをプロンプトへ
#zmodule asciiship            # Spaceship/Starship 風の ASCII 軽量版

# -----------------------------------------------------------------------------
# 補完
# -----------------------------------------------------------------------------
zmodule zsh-users/zsh-completions --fpath src   # 追加補完定義
zmodule completion                              # 賢い補完（補完定義の後に置く）
zmodule Aloxaf/fzf-tab                          # fzf ベースの補完

# -----------------------------------------------------------------------------
#  その他
# -----------------------------------------------------------------------------
zmodule olets/zsh-abbr #alias


# -----------------------------------------------------------------------------
# 管理済み
# -----------------------------------------------------------------------------
zmodule Mekann2904/zsh-clipboard   --source clipboard.plugin.zsh
zmodule Mekann2904/zsh-git         --source git.plugin.zsh
#zmodule Mekann2904/zsh-kitty       --source kitty.plugin.zsh
zmodule Mekann2904/zsh-eza         --source eza.plugin.zsh
zmodule Mekann2904/zsh-fgit        --source fgit.plugin.zsh
#zmodule Mekann2904/zsh-timer-tui   --source timer-tui.plugin.zsh
#zmodule Mekann2904/zsh-bat

# -----------------------------------------------------------------------------
# 末尾初期化が必要なモジュール
# -----------------------------------------------------------------------------
# Fish ライクな自動サジェスト
# 高速化したい場合は ~/.zshrc に `ZSH_AUTOSUGGEST_MANUAL_REBIND=1` を追記
zmodule zsh-users/zsh-autosuggestions

# 構文ハイライト（どちらか一方のみ使用）
# 推奨: fast-syntax-highlighting
zmodule zdharma-continuum/fast-syntax-highlighting
typeset -gA FAST_HIGHLIGHT
FAST_HIGHLIGHT[check-path]=0


# -----------------------------------------------------------------------------
# 補完ダンプのコンパイル（起動高速化）
# -----------------------------------------------------------------------------
if [[ -s ~/.zcompdump && ( ! -s ~/.zcompdump.zwc || ~/.zcompdump -nt ~/.zcompdump.zwc ) ]]; then
  zcompile ~/.zcompdump
fi

